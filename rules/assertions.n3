PREFIX math: <http://www.w3.org/2000/10/swap/math#>
PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX list: <http://www.w3.org/2000/10/swap/list#>
PREFIX tuner: <https://api-tuner.described.at/>
prefix string: <http://www.w3.org/2000/10/swap/string#>
prefix log: <http://www.w3.org/2000/10/swap/log#>
prefix file: <http://www.w3.org/2000/10/swap/file#>

{
  ?expr tuner:assertThat ?msg .
} <= {
  (
    ?expr
    true
    {
      (
        { ?msg!log:rawType list:in ( log:Literal rdf:List ) }
        { ?msg^tuner:logFailedAssertion }
        { ?expr^tuner:logFailedAssertion }
      ) log:ifThenElseIn [].
      true log:equalTo false .
    }
  ) log:ifThenElseIn [] .
} .

{
  ?res tuner:http_code ?value .
} <= {
 ( ?res tuner:http_code ?value ) <#curl-field> [] .
} .

{
  ?res tuner:url.host ?value .
} <= {
  ( ?res tuner:url.host ?value ) <#curl-field> [] .
} .

{
  ( ?res ?prop ?value ) <#curl-field> [] .
} <= {
  ?res log:includes {
    [] a tuner:Response ;
    ?prop ?actualValue .
  } .

  ?prop log:localName ?localName .

  (
    { ?actualValue log:equalTo ?value }
    true
    {
      ("Expected " ?localName " " ?value " but got " ?actualValue)!string:concatenation^tuner:info .
      true log:equalTo false .
    }
  ) log:ifThenElseIn ?SCOPE .
} .

{
  ?res tuner:body ?body .
} <= {
  ?res log:includes {
    [] a tuner:Response ; tuner:body ?bodyPath .
  } .

  (
    {
      ?bodyPath log:rawType log:Literal .
    }
    {
      ("cat " ?bodyPath)!string:concatenation log:shell ?body .
    }
    {
      ?bodyPath log:semantics ?body .
    }
  ) log:ifThenElseIn [] .
} .

{
  ?res tuner:jsonPath ( ?path ?expected ) .
} <= {
  ?res tuner:jsonPath ( ?path ?expected log:equalTo ) .
} .

{
  ?res tuner:jsonPath ( ?path ?expected ?builtIn ) .
} <= {
  ?res log:includes {
    [] a tuner:Response ; tuner:body ?bodyPath .
  } .
  ( "cat " ?bodyPath " | " "bin/jsonpath.sh"!file:libPath " '" ?path "' " )!string:concatenation log:shell ?actualRaw .

  # remove surrounding quotes added by the shell
  ( ( ?actualRaw '^\"' "")!string:replace '\"$' "") string:replace ?actual .

  ( ?actual ?builtIn ) math:normaliseLiteral ?actualNormalised .
  ( ?expected ?builtIn ) math:normaliseLiteral ?expectedNormalised .

  (
    { ?actualNormalised ?builtIn ?expectedNormalised }
    true
    {
      ("Expected JSON path '" ?path "' to satisfy '" ?builtIn " " ?expected "' but got '" ?actual "'")!string:concatenation^tuner:info .
      true log:equalTo false .
    }
  ) log:ifThenElseIn ?SCOPE .
} .

{
  ?res tuner:header ( ?name ?value ) .
} <= {
  ?res tuner:header ( ?name ?value log:equalTo ) .
}.

{
  ?res tuner:header ( ?name ?value ?builtIn ) .
} <= {
  ?name log:rawType log:Literal .
  ?name string:lowerCase ?nameLower .

  (
    {
      ?res log:notIncludes {
        [] a tuner:Response ;
        tuner:headers [
          tuner:name ?nameLower ;
        ] .
      } .
    }
    {
      ("Expected header '" ?name "' but it was not present in the response")!string:concatenation^tuner:info .
      true log:equalTo false .
    }
    true
  ) log:ifThenElseIn [] .

  ?res log:includes {
    [] a tuner:Response ;
    tuner:headers [
      tuner:name ?nameLower ;
      tuner:value ?actualValue ;
    ] .
  } .

  ( ?actualValue ?builtIn ) math:normaliseLiteral ?actualNormalised .
  ( ?value ?builtIn ) math:normaliseLiteral ?expectedNormalised .

  (
    { ?actualNormalised ?builtIn ?expectedNormalised }
    true
    {
      ("Expected header '" ?name "' '" ?value "' to satisfy '" ?builtIn "' but got '" ?actualValue "'")!string:concatenation^tuner:info .
      true log:equalTo false .
    }
  ) log:ifThenElseIn ?SCOPE .
} .
