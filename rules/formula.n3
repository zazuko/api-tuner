prefix earl: <http://www.w3.org/ns/earl#>
prefix log: <http://www.w3.org/2000/10/swap/log#>
prefix tuner: <https://api-tuner.described.at/>
prefix graph: <http://www.w3.org/2000/10/swap/graph#>
prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#>
prefix string: <http://www.w3.org/2000/10/swap/string#>

{
  ?test a earl:TestCase ; tuner:formula ?formula .

  # Choose text to match against: prefer rdfs:label, otherwise the term's URI form
  { ?test rdfs:label ?text . } log:callWithOptional { ?test log:uri ?text . } .

  (
    {
      [] tuner:grep ?pattern .
    }
    {
      ?text!string:lowerCase string:matches ?pattern!string:lowerCase .
    }
    true
  ) log:ifThenElseIn [] .


  (
    ?formula
    {
      ?outcome log:equalTo earl:passed
    }
    {
      ?outcome log:equalTo earl:failed
    }
  ) log:ifThenElseIn [] .
} => {
   ?test earl:outcome ?outcome .
} .
